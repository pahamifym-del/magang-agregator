# ========================
# DJANGO
# ========================
# Ganti dengan string acak panjang (min. 50 karakter)
# Generator: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=9elFCxBjRTIGEJpCTdHioxFwIeL3pwifQ7GsjzQOHnWNzfom8Hy9YqmNq-yi-OWMM64

# "True" untuk development lokal, "False" untuk production
DJANGO_DEBUG=True

# Domain yang diizinkan mengakses Django
# Contoh production: yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Environment aktif: development atau production
DJANGO_SETTINGS_MODULE=config.settings.development

# ========================
# DATABASE (PostgreSQL)
# ========================
POSTGRES_DB=magang_agregator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cobacoba123
POSTGRES_HOST=db          # Nama service di docker-compose
POSTGRES_PORT=5432

# ========================
# REDIS
# ========================
REDIS_URL=redis://redis:6379/0

# ========================
# CELERY
# ========================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ========================
# SENTRY (Monitoring Error)
# ========================
# Dapatkan DSN dari sentry.io setelah buat project
SENTRY_DSN=

# ========================
# OAUTH (Autentikasi)
# ========================
# Isi setelah setup OAuth provider (Google, dll)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ========================
# FRONTEND (Next.js)
# ========================
# URL backend API yang diakses frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1